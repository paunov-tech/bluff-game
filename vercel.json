{
  "framework": "vite",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js":              { "maxDuration": 30 },
    "api/pre-generate.js":   { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/pre-generate", "schedule": "0 */6 * * *" }
  ],
  "headers": [
    { "source": "/api/(.*)", "headers": [{ "key": "Cache-Control", "value": "no-store" }] }
  ]
}
