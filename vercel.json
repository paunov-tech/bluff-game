{
  "framework": "vite",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/duel/:id", "destination": "/index.html" },
    { "source": "/party/:code", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/pre-generate", "schedule": "0 */6 * * *" },
    { "path": "/api/cron-daily", "schedule": "0 23 * * *" },
    { "path": "/api/cron-axiom-reset", "schedule": "0 0 * * 0" }
  ],
  "headers": [
    { "source": "/api/(.*)", "headers": [{ "key": "Cache-Control", "value": "no-store" }] }
  ]
}
